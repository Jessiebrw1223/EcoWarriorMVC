<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - EcoWarrior</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<div class="app-shell">
    <aside class="sidebar">
        <div class="brand"><span class="brand-mark">🌱</span><span>EcoWarrior</span></div>
        <nav class="nav-stack">
            <a href="/" class="nav-link"><span class="nav-icon">⌂</span>Inicio</a>
            <a href="/Challenges" class="nav-link"><span class="nav-icon">◇</span>Retos</a>
            <a href="/Ranking" class="nav-link"><span class="nav-icon">△</span>Clasificación</a>
            <a href="/Profile" class="nav-link"><span class="nav-icon">○</span>Perfil</a>
            <a href="/Contact" class="nav-link"><span class="nav-icon">✉</span>Contacto</a>
            <a href="/AiAgent" class="nav-link"><span class="nav-icon">✦</span>EcoGuide AI</a>
        </nav>
        <div class="sidebar-bottom">
            @if (Context.Session.GetInt32("UserId") != null)
            {
                <span class="user-pill">@Context.Session.GetString("UserName")</span>
                <a href="/Account/Logout" class="nav-link"><span class="nav-icon">↪</span>Cerrar sesión</a>
            }
            else
            {
                <a href="/Account/Login" class="btn btn-success w-100">Ingresar</a>
                <a href="/Account/Register" class="btn btn-outline-success w-100">Crear cuenta</a>
            }
            <div class="side-panel">
                <strong>Reto diario</strong>
                <p>Completa una misión sostenible y suma puntos para tu ranking.</p>
            </div>
        </div>
    </aside>
    <main class="content">
        <div class="topbar">
            <small>@(ViewData["Title"] ?? "Panel")</small>
            <small>En línea <span class="status-dot"></span></small>
        </div>
        @RenderBody()
    </main>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
