<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EcoWarrior MVC</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @{
        var isDashboard = ViewData["IsDashboard"] as bool? == true;
    }

    @if (!isDashboard)
    {
        <header>
            <nav class="navbar navbar-expand-lg navbar-dark eco-navbar shadow-sm">
                <div class="container">
                    <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">EcoWarrior MVC</a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse" id="mainNav">
                        <ul class="navbar-nav ms-auto gap-lg-2">
                            <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Inicio</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Productos" asp-action="Index">Productos</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Nosotros">Nosotros</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Contacto">Contacto</a></li>
                        </ul>
                    </div>
                </div>
            </nav>
        </header>
    }

    <main>
        @RenderBody()
    </main>

    @if (!isDashboard)
    {
        <footer class="border-top footer text-muted py-4 mt-5">
            <div class="container d-flex flex-column flex-md-row justify-content-between gap-2">
                <span>© 2026 - EcoWarrior MVC</span>
                <span>Base MVC inspirada en tu referencia EcoWarrior.</span>
            </div>
        </footer>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
