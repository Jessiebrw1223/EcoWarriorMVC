@model IReadOnlyList<Producto>
@{
    ViewData["Title"] = "Productos";
}

<section class="container py-5">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
        <div>
            <h1 class="fw-bold mb-1">Catálogo MVC</h1>
            <p class="text-secondary mb-0">Vista de listado controlada por ProductosController.</p>
        </div>
        @if (ViewBag.Categoria is string categoria && !string.IsNullOrWhiteSpace(categoria))
        {
            <a class="btn btn-outline-secondary" asp-action="Index">Quitar filtro: @categoria</a>
        }
    </div>

    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-md-6 col-xl-3">
                <div class="card h-100 border-0 shadow-sm product-card">
                    <img src="@item.ImagenUrl" class="card-img-top" alt="@item.Nombre" />
                    <div class="card-body d-flex flex-column">
                        <span class="badge text-bg-light mb-2 align-self-start">@item.Categoria</span>
                        <h5 class="card-title">@item.Nombre</h5>
                        <p class="card-text text-secondary small flex-grow-1">@item.Descripcion</p>
                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <span class="fw-bold">S/ @item.Precio</span>
                            <a class="btn btn-success btn-sm" asp-action="Detalle" asp-route-id="@item.Id">Ver más</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</section>
