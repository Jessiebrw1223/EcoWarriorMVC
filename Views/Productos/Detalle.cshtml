@model Producto
@{
    ViewData["Title"] = "Detalle";
}

<section class="container py-5">
    <div class="row g-4 align-items-center">
        <div class="col-lg-6">
            <img src="@Model.ImagenUrl" alt="@Model.Nombre" class="img-fluid rounded-4 shadow-sm" />
        </div>
        <div class="col-lg-6">
            <span class="badge text-bg-success mb-3">@Model.Categoria</span>
            <h1 class="fw-bold mb-3">@Model.Nombre</h1>
            <p class="text-secondary">@Model.Descripcion</p>
            <h3 class="fw-bold mb-3">S/ @Model.Precio</h3>
            <p><strong>Stock:</strong> @Model.Stock unidades</p>
            <div class="d-flex gap-3 mt-4">
                <a class="btn btn-success" asp-action="Index">Volver al catálogo</a>
                <a class="btn btn-outline-dark" asp-controller="Home" asp-action="Contacto">Solicitar información</a>
            </div>
        </div>
    </div>
</section>
